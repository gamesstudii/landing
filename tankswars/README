      // Парсим Markdown и вставляем в контейнер
      const targetDiv = document.getElementById('markdown-content');
      if (targetDiv && typeof marked !== 'undefined') {
        // Настройки marked
        marked.setOptions({
          breaks: false,
          gfm: true,
          headerIds: false,
          mangle: false,
          smartLists: true,
        });
        targetDiv.innerHTML = marked.parse(mdSource);
      } else {
        targetDiv.innerHTML = '<p>Ошибка загрузки парсера Markdown.</p>';
      }
    })();
